// ─── ② メインエントリーポイント ─────────────────────────────
function runMorningAnalysis() {
  // 土日はスキップ
  const day = new Date().getDay(); // 0=日, 1=月, ..., 6=土
  if (day === 0 || day === 6) {
    Logger.log('土日のためスキップ');
    return;
  }

  // 祝日チェック（Googleカレンダーの日本祝日を利用）
  if (isJapaneseHoliday()) {
    Logger.log('祝日のためスキップ');
    return;
  }
  
  // 設定値の検証（未設定のままだと即エラーで止める）
  if (!PROPS.getProperty('CLAUDE_API_KEY') || 
       PROPS.getProperty('CLAUDE_API_KEY').startsWith("sk-ant-xxx")) {
    throw new Error("【設定エラー】CLAUDE_API_KEY が未設定です。CONFIGに正しいAPIキーを入力してください。");
  }
  if (!PROPS.getProperty('NOTIFY_EMAIL') || 
       PROPS.getProperty('NOTIFY_EMAIL') === "your-email@gmail.com") {
    throw new Error("【設定エラー】NOTIFY_EMAIL が未設定です。CONFIGに通知先メールアドレスを入力してください。");
  }

  try {
    Logger.log("=== FX朝の買い時判定 開始 ===");

    const fxData   = fetchFxData();
    const analysis = analyzeWithClaude(fxData);
    sendEmailReport(fxData, analysis);

    Logger.log("=== 完了 ===");
  } catch (e) {
    Logger.log("エラー: " + e.message);
    sendErrorEmail(e.message);
  }
}

// ─── ③ FXデータ取得 ─────────────────────────────────────────
function fetchFxData() {
  // (A) 現在レート（ExchangeRate-API 無料プラン）
  const rateRes  = UrlFetchApp.fetch(
    "https://open.er-api.com/v6/latest/USD",
    { muteHttpExceptions: true }
  );
  const rateJson = JSON.parse(rateRes.getContentText());
  if (rateJson.result !== "success") throw new Error("レート取得失敗: " + rateRes.getContentText());

  const currentRate = rateJson.rates["JPY"];
  const fetchedAt   = rateJson.time_last_update_utc;

  // (B) 過去40日分の日次OHLC（Yahoo Finance API - GASからアクセス可能）
  const yahooUrl = "https://query1.finance.yahoo.com/v8/finance/chart/USDJPY%3DX"
                 + "?interval=1d&range=2mo";
  const yahooRes = UrlFetchApp.fetch(yahooUrl, { muteHttpExceptions: true });
  if (yahooRes.getResponseCode() !== 200) {
    throw new Error("Yahoo Finance APIエラー (HTTP " + yahooRes.getResponseCode() + ")");
  }
  const yahooJson = JSON.parse(yahooRes.getContentText());
  const history   = parseYahooFinance(yahooJson, 30); // 直近30営業日

  // (C) テクニカル指標を計算
  const closes   = history.map(r => r.close);
  const ma5      = calcSMA(closes, 5);
  const ma25     = calcSMA(closes, 25);
  const rsi14    = calcRSI(closes, 14);
  const { upper, lower } = calcBollinger(closes, 20, 2);
  const macd     = calcMACD(closes, 12, 26, 9);

  Logger.log(`現在レート: ${currentRate} JPY/USD`);
  Logger.log(`MA5: ${ma5}  MA25: ${ma25}  RSI14: ${rsi14}`);

  return {
    currentRate,
    fetchedAt,
    history,      // [{date, open, high, low, close, volume}, ...]
    indicators: { ma5, ma25, rsi14, bollingerUpper: upper, bollingerLower: lower, macd },
  };
}

// ─── ④ Yahoo Finance レスポンスパーサー ─────────────────────
function parseYahooFinance(json, limit) {
  const result = json.chart && json.chart.result && json.chart.result[0];
  if (!result) throw new Error("Yahoo Finance: データが空です");

  const timestamps = result.timestamp;
  const quote      = result.indicators.quote[0];
  const rows       = [];

  for (let i = 0; i < timestamps.length; i++) {
    const close = quote.close[i];
    if (!close) continue; // null/NaN は除外（週末・祝日）
    const d = new Date(timestamps[i] * 1000);
    const dateStr = Utilities.formatDate(d, "UTC", "yyyy-MM-dd");
    rows.push({
      date:  dateStr,
      open:  Math.round((quote.open[i]  || close) * 100) / 100,
      high:  Math.round((quote.high[i]  || close) * 100) / 100,
      low:   Math.round((quote.low[i]   || close) * 100) / 100,
      close: Math.round(close * 100) / 100,
      volume: quote.volume ? quote.volume[i] : null,
    });
  }

  // 直近 limit 件を返す
  return rows.slice(-limit);
}

// ─── ⑤ テクニカル指標計算 ────────────────────────────────────
function calcSMA(data, period) {
  if (data.length < period) return null;
  const slice = data.slice(-period);
  return Math.round(slice.reduce((a, b) => a + b, 0) / period * 100) / 100;
}

function calcRSI(data, period) {
  if (data.length < period + 1) return null;
  const slice = data.slice(-(period + 1));
  let gains = 0, losses = 0;
  for (let i = 1; i < slice.length; i++) {
    const diff = slice[i] - slice[i - 1];
    if (diff > 0) gains  += diff;
    else          losses -= diff;
  }
  const avgGain = gains  / period;
  const avgLoss = losses / period;
  if (avgLoss === 0) return 100;
  const rs = avgGain / avgLoss;
  return Math.round((100 - 100 / (1 + rs)) * 100) / 100;
}

function calcBollinger(data, period, sigma) {
  if (data.length < period) return { upper: null, lower: null };
  const slice  = data.slice(-period);
  const mean   = slice.reduce((a, b) => a + b, 0) / period;
  const variance = slice.reduce((a, b) => a + (b - mean) ** 2, 0) / period;
  const sd     = Math.sqrt(variance);
  return {
    upper: Math.round((mean + sigma * sd) * 100) / 100,
    lower: Math.round((mean - sigma * sd) * 100) / 100,
  };
}

function calcEMA(data, period) {
  if (data.length < period) return null;
  const k   = 2 / (period + 1);
  let ema   = data.slice(0, period).reduce((a, b) => a + b, 0) / period;
  for (let i = period; i < data.length; i++) {
    ema = data[i] * k + ema * (1 - k);
  }
  return Math.round(ema * 100) / 100;
}

function calcMACD(data, fast, slow, signal) {
  const emaFast   = calcEMA(data, fast);
  const emaSlow   = calcEMA(data, slow);
  if (!emaFast || !emaSlow) return { macd: null, signal: null, histogram: null };
  const macdLine  = Math.round((emaFast - emaSlow) * 100) / 100;
  // signal は簡易計算（直近データが少ない場合はnull）
  return { macd: macdLine, signal: null, histogram: null };
}

// ─── ⑥ Claude API で分析 ────────────────────────────────────
function analyzeWithClaude(fxData) {
  const { currentRate, fetchedAt, history, indicators } = fxData;
  const { ma5, ma25, rsi14, bollingerUpper, bollingerLower, macd } = indicators;

  // 直近5日の終値テーブル
  const recentRows = history.slice(-5)
    .map(r => `  ${r.date}: 始値${r.open} / 高値${r.high} / 安値${r.low} / 終値${r.close}`)
    .join("\n");

  const prompt = `
あなたは為替トレーダー向けのFXアナリストです。
以下のUSD/JPYのデータをもとに、FX初心者にも分かりやすいように本日の「買い時かどうか」を判定してください。

## 現在レート
- USD/JPY: ${currentRate} 円（取得時刻: ${fetchedAt}）

## 直近5営業日の価格
${recentRows}

## テクニカル指標（直近値）
- 5日移動平均（MA5）  : ${ma5 ?? "データ不足"}
- 25日移動平均（MA25） : ${ma25 ?? "データ不足"}
- RSI（14日）         : ${rsi14 ?? "データ不足"}
- ボリンジャーバンド上限（2σ）: ${bollingerUpper ?? "データ不足"}
- ボリンジャーバンド下限（2σ）: ${bollingerLower ?? "データ不足"}
- MACD（12-26）       : ${macd.macd ?? "データ不足"}

## 投資スタイル
${PROPS.getProperty('INVESTMENT_STYLE')}

---
### 回答フォーマット
回答は必ず以下のフォーマットで、プレーンテキストで記述してください。
マークダウン記法（#, ##, **, --, --- など）は一切使用しないでください。
箇条書きは ・ を使ってください。

【総合判定】
買い推奨 / 様子見 / 見送り　のいずれか1つを明記してください。

【根拠】
テクニカル指標の読み方を3〜5点、・ で始まる箇条書きで説明してください。

【注意点・リスク】
現在の相場で注意すべきリスクを2〜3点挙げてください。

【目標レート（任意）】
エントリーを検討するレートと、損切りの目安を記載してください。

【一言コメント】
今日の相場を一言で表してください。

※ 投資助言ではなく、あくまで参考情報として提供してください。
`;

  const payload = {
    model:      PROPS.getProperty('CLAUDE_MODEL'),
    max_tokens: 1024,
    messages:   [{ role: "user", content: prompt }],
  };

  const options = {
    method:             "post",
    contentType:        "application/json",
    headers: {
      "x-api-key":          PROPS.getProperty('CLAUDE_API_KEY'),
      "anthropic-version":  "2023-06-01",
    },
    payload:            JSON.stringify(payload),
    muteHttpExceptions: true,
  };

  const res      = UrlFetchApp.fetch("https://api.anthropic.com/v1/messages", options);
  const resJson  = JSON.parse(res.getContentText());

  if (res.getResponseCode() !== 200) {
    throw new Error("Claude APIエラー: " + res.getContentText());
  }

  const rawText = resJson.content[0].text;
  return stripMarkdown(rawText);
}

// ─── Markdown除去（念のため残った記号を除去） ───────────────
function stripMarkdown(text) {
  return text
    .replace(/^#{1,6}\s*/gm, "")        // ## 見出し
    .replace(/\*\*(.+?)\*\*/g, "$1")  // **太字**
    .replace(/\*(.+?)\*/g, "$1")        // *イタリック*
    .replace(/^---+$/gm, "────────────") // --- 区切り線 → 読みやすい線に
    .replace(/^- /gm, "・ ")              // - リスト → ・
    .trim();
}

