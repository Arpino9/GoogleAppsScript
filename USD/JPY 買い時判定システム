// ─── ⑧ エラー通知メール ─────────────────────────────────────
function sendErrorEmail(errorMsg) {
  const jstStr = Utilities.formatDate(new Date(), "Asia/Tokyo", "yyyy/MM/dd HH:mm");
  GmailApp.sendEmail(
    PROPS.getProperty('NOTIFY_EMAIL'),
    `⚠️ USD/JPY 朝の判定でエラーが発生しました ${jstStr}`,
    `エラー内容:\n${errorMsg}\n\nGASのログを確認してください。`
  );
}

// ============================================================
// 祝日判定（Googleカレンダーの日本祝日を利用）
// ============================================================
function isJapaneseHoliday() {
  const today    = new Date();
  const calendar = CalendarApp.getCalendarById('ja.japanese#holiday@group.v.calendar.google.com');
  const events   = calendar.getEventsForDay(today);
  return events.length > 0;
}

